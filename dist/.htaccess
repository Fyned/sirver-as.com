# LiteSpeed Cache - Devre Dışı Bırak (SPA için)
<IfModule LiteSpeed>
  CacheLookup off
</IfModule>

# Cache-Control Headers
<IfModule mod_headers.c>
  # HTML dosyaları için cache'i devre dışı bırak
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </FilesMatch>

  # Statik varlıklar için uzun süreli cache (hash'li dosyalar)
  <FilesMatch "\.(js|css|jpg|jpeg|png|gif|webp|svg|woff2|woff|ttf|eot|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# LiteSpeed özel: HTML için cache kapalı
<IfModule LiteSpeed>
  RewriteEngine On
  RewriteRule \.html$ - [E=Cache-Control:no-cache]
</IfModule>

# SPA Routing - Tüm yolları index.html'e yönlendir
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/api/
  RewriteRule . /index.html [L]
</IfModule>

# Gzip Sıkıştırma
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
